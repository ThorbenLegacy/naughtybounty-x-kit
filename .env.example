# Kopieren nach .env.local und Werte eintragen
# Postet als @LucaBrandblue (Promo für NaughtyBounty)

# OAuth 2.0 (empfohlen — braucht media.write für Bilder)
X_CLIENT_ID=
X_CLIENT_SECRET=
X_OAUTH2_ACCESS_TOKEN=
X_OAUTH2_REFRESH_TOKEN=

# OAuth 1.0a (Alternative für Media-Upload, falls OAuth2 nicht geht)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Dashboard-Login (umbra / zero / shade — gemeinsames Passwort)
# Standard ohne Setzen: nb-umbra-zero-shade — bitte in Produktion ändern!
DASHBOARD_PASSWORD=
# Optional: Session-Signatur (zufälliger String)
# DASHBOARD_SESSION_SECRET=
# Lokal ohne Login: DASHBOARD_AUTH_DISABLED=1
